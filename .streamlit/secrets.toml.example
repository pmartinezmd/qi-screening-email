# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Cloud, paste these key=value pairs into the app's Secrets panel
# (Settings → Secrets) — do NOT commit secrets.toml to git.

# ── Column mapping ────────────────────────────────────────────────────────────
# Column names in your EMR export / filled template.
PROVIDER_COL       = "Encounter Provider"
PROBLEMS_COL       = "Problems"
DIAGNOSIS_KEYWORDS = "lupus, SLE, JIA, juvenile arthritis, polyarticular, oligoarticular"

# ── Screening components ───────────────────────────────────────────────────────
# One [[components]] block per measure.
# has_date = true  → template gets a "{label} Date" column; date must be within lookback window.
# has_date = false → only checks that the value column is non-empty.

[[components]]
label    = "Lipids"
has_date = true

[[components]]
label    = "HbA1c"
has_date = true

[[components]]
label    = "Blood Pressure"
has_date = false

[[components]]
label    = "BMI"
has_date = false

[[components]]
label    = "Smoking Status"
has_date = false

# ── Branding (also editable in the app sidebar) ───────────────────────────────
SCREENING_NAME = "Screening QI"
TEAM_LABEL     = "QI Team · Your Institution"
FROM_NAME      = "Screening QI Team"

# ── Email content ─────────────────────────────────────────────────────────────
TARGET_RATE    = "80"          # screening target percentage shown in emails
DASHBOARD_URL  = ""            # optional link shown in the email nudge section

# ── SMTP settings ─────────────────────────────────────────────────────────────
SMTP_HOST      = "smtp.office365.com"
SMTP_PORT      = "587"
SMTP_USER      = "your.email@institution.edu"
# Note: SMTP password is entered at send time in the app, never stored here.

# ── Provider list ─────────────────────────────────────────────────────────────
# Add one [[providers]] block per provider.
# provider_id must match exactly how the name appears in the EMR export.
# provider_type must be "attending" or "fellow".

[[providers]]
provider_id   = "SMITH, JANE A"
display_name  = "Dr. Jane Smith"
email         = "jsmith@institution.edu"
provider_type = "attending"

[[providers]]
provider_id   = "DOE, JOHN B"
display_name  = "Dr. John Doe"
email         = "jdoe@institution.edu"
provider_type = "fellow"
