# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Cloud, paste these key=value pairs into the app's Secrets panel
# (Settings → Secrets) — do NOT commit secrets.toml to git.

# ── Branding (also editable in the app sidebar) ───────────────────────────────
SCREENING_NAME = "Screening QI"
TEAM_LABEL     = "QI Team · Your Institution"
FROM_NAME      = "Screening QI Team"

# ── Email content ─────────────────────────────────────────────────────────────
TARGET_RATE    = "80"          # screening target percentage shown in emails
DASHBOARD_URL  = ""            # optional link shown in the email nudge section

# ── SMTP settings ─────────────────────────────────────────────────────────────
SMTP_HOST      = "smtp.office365.com"
SMTP_PORT      = "587"
SMTP_USER      = "your.email@institution.edu"
# Note: SMTP password is entered at send time in the app, never stored here.
