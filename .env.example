# Neither EXCEL_PASSWORD nor SMTP_PASSWORD is stored here.
# Both are prompted at runtime and never written to disk.

# SMTP settings
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your.email@institution.edu

# Displayed in email header, footer, and Streamlit app
FROM_NAME=Screening QI Team
TEAM_LABEL=QI Team · Your Institution

# Short name for the screening project — used in email subject and app title
SCREENING_NAME=Screening QI

# Optional: link to a dashboard shown in the email nudge section
DASHBOARD_URL=
